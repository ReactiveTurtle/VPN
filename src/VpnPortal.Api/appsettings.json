{
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "__APP_DATABASE_CONNECTION_STRING__"
  },
  "Email": {
    "Enabled": true,
    "Provider": "Smtp",
    "Host": "__APP_EMAIL_HOST__",
    "Port": 587,
    "UseSsl": true,
    "Username": "__APP_EMAIL_USERNAME__",
    "Password": "__APP_EMAIL_PASSWORD__",
    "FromEmail": "__APP_EMAIL_FROM_EMAIL__",
    "FromName": "__APP_EMAIL_FROM_NAME__",
    "PublicBaseUrl": "__APP_EMAIL_PUBLIC_BASE_URL__"
  },
  "InternalApi": {
    "SharedSecret": "__APP_INTERNAL_API_SHARED_SECRET__"
  },
  "VpnAccess": {
    "ServerAddress": "__APP_VPN_ACCESS_SERVER_ADDRESS__"
  },
  "VpnRuntime": {
    "DisconnectScriptPath": "__APP_VPN_RUNTIME_DISCONNECT_SCRIPT_PATH__"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
