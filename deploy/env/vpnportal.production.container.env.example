ASPNETCORE_ENVIRONMENT=Production
Database__ConnectionString=Host=host.docker.internal;Port=5432;Database=vpn_portal;Username=vpn_portal_app;Password=change-me
Email__Enabled=true
Email__Provider=Smtp
Email__Host=smtp.example.com
Email__Port=587
Email__UseSsl=true
Email__Username=username
Email__Password=password
Email__FromEmail=no-reply@example.com
Email__FromName=VPN Portal
Email__PublicBaseUrl=https://vpn.example.com
InternalApi__SharedSecret=change-me-internal-api-secret
VpnAccess__ServerAddress=vpn.example.com
VpnRuntime__DisconnectScriptPath=/usr/local/lib/vpnportal/disconnect-session.sh
