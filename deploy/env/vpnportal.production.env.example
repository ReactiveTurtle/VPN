ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5000
Database__Provider=PostgreSql
Database__ConnectionString=Host=127.0.0.1;Port=5432;Database=vpn_portal;Username=vpn_portal_app;Password=change-me
Email__Enabled=true
Email__Provider=Smtp
Email__Host=smtp.example.com
Email__Port=587
Email__UseSsl=true
Email__Username=username
Email__Password=password
Email__FromEmail=no-reply@example.com
Email__FromName=VPN Portal
Email__PublicBaseUrl=https://vpn.example.com
