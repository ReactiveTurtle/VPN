ASPNETCORE_ENVIRONMENT=Staging
ASPNETCORE_URLS=http://127.0.0.1:5001
Database__Provider=PostgreSql
Database__ConnectionString=Host=127.0.0.1;Port=5432;Database=vpn_portal_staging;Username=vpn_portal_app;Password=change-me
Email__Enabled=true
Email__Provider=Smtp
Email__Host=smtp.example.com
Email__Port=587
Email__UseSsl=true
Email__Username=username
Email__Password=password
Email__FromEmail=no-reply-staging@example.com
Email__FromName=VPN Portal Staging
Email__PublicBaseUrl=https://staging-vpn.example.com
