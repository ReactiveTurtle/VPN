VPN_HOST_FQDN=vpn.example.com
VPN_HOST_PUBLIC_IP=203.0.113.10

PORTAL_PUBLIC_URL=https://vpn.example.com
INTERNAL_API_BASE_URL=https://vpn.example.com
PORTAL_DEPLOY_ROOT=/opt/vpnportal
PORTAL_ENV_DIR=/etc/vpnportal
PORTAL_ENV_FILE=/etc/vpnportal/vpnportal.production.env
INTERNAL_API_SHARED_SECRET=change-me-internal-api-secret

POSTGRES_DB=vpn_portal
POSTGRES_APP_USER=vpn_portal_app
POSTGRES_APP_PASSWORD=change-me-app
POSTGRES_RADIUS_USER=vpn_portal_radius
POSTGRES_RADIUS_PASSWORD=change-me-radius

RADIUS_SHARED_SECRET=change-me-radius-secret
RADIUS_CLIENT_ADDRESS=127.0.0.1

STRONGSWAN_SERVER_ID=vpn.example.com
STRONGSWAN_CERT_PATH=/etc/ipsec.d/certs/server-cert.pem
STRONGSWAN_KEY_PATH=/etc/ipsec.d/private/server-key.pem
STRONGSWAN_CA_CERT_PATH=/etc/ipsec.d/cacerts/ca-cert.pem
STRONGSWAN_RIGHT_SOURCE_IP=10.10.10.0/24,fd00:1234::/64
STRONGSWAN_DNS=8.8.8.8,8.8.4.4,1.1.1.1

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=username
SMTP_PASSWORD=password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=VPN Portal

SUPERADMIN_USERNAME=rootadmin
SUPERADMIN_PASSWORD_HASH=replace-with-generated-argon2id-hash
