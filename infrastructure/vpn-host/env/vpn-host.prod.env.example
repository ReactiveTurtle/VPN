TARGET=prod

# Public portal URL. Also used as the default internal API base URL.
PUBLIC_BASE_URL=https://vpn.example.com

# VPN endpoint shown to users and used as the default strongSwan server ID.
VPN_SERVER_ADDRESS=vpn.example.com

InternalApi__SharedSecret=change-me-internal-api-secret

POSTGRES_APP_PASSWORD=change-me-app
POSTGRES_RADIUS_PASSWORD=change-me-radius

RADIUS_SHARED_SECRET=change-me-radius-secret

STRONGSWAN_RIGHT_SOURCE_IP=10.10.10.0/24,fd00:1234::/64
STRONGSWAN_DNS=8.8.8.8,8.8.4.4,1.1.1.1

Email__Host=smtp.example.com
Email__Username=username
Email__Password=password
Email__FromEmail=no-reply@example.com

# Optional overrides. Leave commented unless you need non-default values.
# INTERNAL_API_BASE_URL=https://internal-api.example.com
# PORTAL_DEPLOY_ROOT=/opt/vpnportal
# PORTAL_ENV_DIR=/etc/vpnportal
# PORTAL_ENV_FILE=/etc/vpnportal/vpnportal.prod.container.env
# POSTGRES_DB=vpn_portal
# POSTGRES_APP_USER=vpn_portal_app
# POSTGRES_RADIUS_USER=vpn_portal_radius
# RADIUS_CLIENT_ADDRESS=127.0.0.1
# STRONGSWAN_SERVER_ID=vpn.example.com
# STRONGSWAN_CERT_PATH=/etc/ipsec.d/certs/server-cert.pem
# STRONGSWAN_KEY_PATH=/etc/ipsec.d/private/server-key.pem
# STRONGSWAN_CA_CERT_PATH=/etc/ipsec.d/cacerts/ca-cert.pem
# VpnAccess__ServerAddress=vpn.example.com
# VpnRuntime__DisconnectScriptPath=/usr/local/lib/vpnportal/disconnect-session.sh
# Email__Port=587
# Email__FromName=VPN Portal
