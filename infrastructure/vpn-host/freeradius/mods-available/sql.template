sql {
    driver = "rlm_sql_postgresql"
    dialect = "postgresql"

    server = "127.0.0.1"
    port = 5432
    login = "${POSTGRES_RADIUS_USER}"
    password = "${POSTGRES_RADIUS_PASSWORD}"
    radius_db = "${POSTGRES_DB}"

    read_clients = no

    # The project uses custom PostgreSQL-backed policy data instead of the
    # default radcheck/radreply schema. The authorize policy in
    # sites-available/default resolves NT-Password from vpn_device_credentials.
}
